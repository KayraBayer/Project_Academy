<script>
        function toggleProfileSidebar(name = '') {
            const sidebar = document.getElementById('profileSidebar');
            const overlay = document.getElementById('profileSidebarOverlay');
            const sidebarName = document.getElementById('sidebarName');
            const sidebarAvatar = document.getElementById('sidebarAvatar');

            if (sidebar.classList.contains('profile-sidebar-active')) {
                sidebar.classList.remove('profile-sidebar-active');
                overlay.classList.add('hidden');
                overlay.classList.remove('opacity-100');
                overlay.classList.add('opacity-0');
            } else {
                if(name) {
                    sidebarName.innerText = name;
                    sidebarAvatar.innerText = name.split(' ').map(n => n[0]).join('');
                }
                sidebar.classList.add('profile-sidebar-active');
                overlay.classList.remove('hidden');
                setTimeout(() => {
                    overlay.classList.remove('opacity-0');
                    overlay.classList.add('opacity-100');
                }, 10);
            }
        }

        // Search bar micro-interaction
        const searchInput = document.querySelector('input[type="text"]');
        searchInput.addEventListener('focus', () => {
            searchInput.parentElement.classList.add('ring-2', 'ring-primary/20', 'bg-surface-container-low');
        });
        searchInput.addEventListener('blur', () => {
            searchInput.parentElement.classList.remove('ring-2', 'ring-primary/20', 'bg-surface-container-low');
        });
    </script>
